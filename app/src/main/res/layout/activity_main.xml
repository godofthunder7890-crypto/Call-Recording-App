<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D0F14"
    android:padding="16dp">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Call Auto Upload"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#E8EAF0"
            android:gravity="center"
            android:paddingTop="20dp"/>
        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="App Paused"
            android:textColor="#4F8EF7"
            android:background="#1E2330"
            android:padding="14dp"
            android:gravity="center"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="16dp"/>
        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switchEnabled"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="App Enable/Disable"
            android:textColor="#E8EAF0"
            android:padding="16dp"
            android:layout_marginBottom="16dp"/>
        <EditText
            android:id="@+id/etTelegramToken"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Telegram Bot Token"
            android:textColor="#E8EAF0"
            android:textColorHint="#3A4055"
            android:background="#1E2330"
            android:padding="12dp"
            android:layout_marginBottom="10dp"/>
        <EditText
            android:id="@+id/etTelegramChatId"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Telegram Chat ID"
            android:textColor="#E8EAF0"
            android:textColorHint="#3A4055"
            android:background="#1E2330"
            android:padding="12dp"
            android:layout_marginBottom="10dp"/>
        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switchTelegram"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Upload to Telegram"
            android:textColor="#E8EAF0"
            android:padding="16dp"
            android:layout_marginBottom="10dp"/>
        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switchDrive"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Upload to Google Drive"
            android:textColor="#E8EAF0"
            android:padding="16dp"
            android:layout_marginBottom="10dp"/>
        <Button
            android:id="@+id/btnSignInDrive"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Sign In with Google"
            android:backgroundTint="#4CAF50"
            android:textColor="#fff"
            android:layout_marginBottom="10dp"/>
        <Button
            android:id="@+id/btnTestTelegram"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Test Telegram"
            android:backgroundTint="#29B6F6"
            android:textColor="#fff"
            android:layout_marginBottom="10dp"/>
        <Button
            android:id="@+id/btnSave"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Settings Save Karo"
            android:backgroundTint="#4F8EF7"
            android:textColor="#fff"
            android:layout_marginBottom="30dp"/>
    </LinearLayout>
</ScrollView>
